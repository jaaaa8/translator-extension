{
  "manifest_version": 3,
  "name": "MangaTranslator",
  "version": "0.1.0",
  "description": "Dịch truyện tranh và overlay lên trang (local server)",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_popup": "popup.html" }
}
